<div class="min-h-screen bg-slate-900 text-white flex flex-col p-8">
  <header class="mb-12 border-b border-slate-700 pb-4">
    <h1 class="text-4xl font-extrabold tracking-tight text-cyan-400">
      Sovereign AI <span class="text-slate-500 font-light">v1.0</span>
    </h1>
    <p class="text-slate-400">Nairobi Node: Active</p>
  </header>

  <main class="flex-grow flex flex-col max-w-4xl mx-auto w-full">
    <div id="messages_container" class="bg-slate-800 rounded-xl p-6 mb-6 h-[60vh] overflow-y-auto border border-slate-700 shadow-2xl flex flex-col gap-6">
      <% @messages.each do |msg| %>
        <div class="<%= msg.role == 'user' ? 'self-end bg-cyan-900/40 border-cyan-800' : 'self-start bg-slate-700/50 border-slate-600' %> p-5 rounded-2xl max-w-[90%] border shadow-sm">
          <span class="text-[10px] font-black tracking-[0.2em] block mb-3 opacity-50 uppercase">
            <%= msg.role == 'user' ? '✦ User Command' : '✦ Nairobi Node Intel' %>
          </span>
          
          <%# The Genius Fix: Rendering Markdown instead of raw text %>
          <div class="prose prose-invert prose-cyan max-w-none text-slate-200 leading-relaxed">
            <%= markdown(msg.content) %>
          </div>
        </div>
      <% end %>
    </div>

    <%= form_with url: messages_path, 
                  data: { 
                    controller: "reset-form", 
                    action: "turbo:submit-end->reset-form#reset" 
                  }, 
                  class: "relative" do |f| %>
      <%= f.text_field :content, 
            placeholder: "Issue a command to the core...", 
            class: "w-full bg-slate-800 border-slate-700 rounded-xl p-5 pr-24 text-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition-all placeholder-slate-500 text-white shadow-inner",
            autocomplete: "off" %>
      <%= f.submit "RUN", 
            class: "absolute right-3 top-3 bg-cyan-600 hover:bg-cyan-500 px-6 py-2 rounded-lg font-bold transition-all transform active:scale-95 cursor-pointer text-white shadow-lg" %>
    <% end %>
  </main>
</div>
